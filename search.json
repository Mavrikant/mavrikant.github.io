---
layout: null
sitemap: false
---
[
{% for post in site.posts %}
  {
    "title": {{ post.title | jsonify }},
    "subtitle": {{ post.subtitle | default: "" | jsonify }},
    "url": {{ post.url | remove: '.html' | relative_url | jsonify }},
    "date": {{ post.date | date: "%Y-%m-%d" | jsonify }},
    "date_display": {% capture d %}{% include tr-month.html date=post.date format="long" %}{% endcapture %}{{ d | jsonify }},
    "tags": {{ post.tags | jsonify }},
    "tag_names": [{% for tag in post.tags %}{{ site.data.tags[tag].name | default: tag | jsonify }}{% unless forloop.last %}, {% endunless %}{% endfor %}],
    "excerpt": {{ post.excerpt | strip_html | normalize_whitespace | truncatewords: 40 | jsonify }},
    "content": {{ post.content | strip_html | normalize_whitespace | truncatewords: 250 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
